# ===== Banco (Railway Postgres) =====
# No Railway: adicione o plugin Postgres; ele cria a variável automaticamente.
DATABASE_URL="postgresql://user:pass@host:5432/railway"

# ===== Admin (login por senha) =====
ADMIN_PASSWORD="troque-esta-senha"
# string aleatória longa usada pra assinar a sessão do admin
ADMIN_SESSION_SECRET="gere-uma-string-aleatoria-longa"

# ===== Upload de fotos (Volume do Railway) =====
# No Railway: crie um Volume e monte em /data; depois aponte aqui:
UPLOAD_DIR="/data/uploads"

# ===== Gateway PIX (Zyropay) =====
# Credenciais enviadas pela Zyropay (suporte@zyropay.com)
ZYROPAY_API_URL="https://gateway-zyropay-api.rancher.codefabrik.dev"
ZYROPAY_CLIENT_ID=""
ZYROPAY_PASSWORD=""
# usado para validar o webhook (campo securityParaphrase). Defina o mesmo valor
# no painel da Zyropay ao cadastrar a URL de notificação.
ZYROPAY_WEBHOOK_SECRET=""
